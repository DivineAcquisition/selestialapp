# =============================================================================
# SELESTIAL ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env.local and fill in your values

# =============================================================================
# SUPABASE CONFIGURATION (Required)
# =============================================================================
# Get these from: https://supabase.com/dashboard/project/_/settings/api

# Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Your Supabase anon/public key (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# Your Supabase service role key (NEVER expose to client - server only)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# =============================================================================
# APPLICATION URLs
# =============================================================================
# The base URL of your application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# STRIPE CONFIGURATION (Required for payments)
# =============================================================================
# Get these from: https://dashboard.stripe.com/apikeys

# Publishable key (safe for client-side)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Secret key (server-side only)
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret (for webhook verification)
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs for subscription plans
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_GROWTH_PRICE_ID=price_...
STRIPE_SCALE_PRICE_ID=price_...

# Public price IDs (for client-side plan display)
NEXT_PUBLIC_STRIPE_STARTER_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_GROWTH_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_ENTERPRISE_PRICE_ID=price_...

# =============================================================================
# TWILIO CONFIGURATION (Required for SMS)
# =============================================================================
# Get these from: https://console.twilio.com/

TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_MESSAGING_SERVICE_SID=MG...

# =============================================================================
# EMAIL CONFIGURATION (Required for transactional emails)
# =============================================================================
# Get from: https://resend.com/api-keys

RESEND_API_KEY=re_...

# Alternative: SendGrid (optional)
# SENDGRID_API_KEY=SG...

# =============================================================================
# AI CONFIGURATION (Required for AI features)
# =============================================================================
# Anthropic Claude API - Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API (optional, fallback) - Get from: https://platform.openai.com/
OPENAI_API_KEY=sk-...

# =============================================================================
# ANALYTICS & MONITORING (Optional)
# =============================================================================
# PostHog Analytics - Get from: https://app.posthog.com/project/settings
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Sentry Error Monitoring - Get from: https://sentry.io/settings/
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# =============================================================================
# ICEBERG ANALYTICS (Optional - for historical data warehousing)
# =============================================================================
# Get these from Supabase Dashboard > Storage > Analytics

# Supabase project reference
SUPABASE_PROJECT_REF=your-project-ref

# Iceberg warehouse name (your analytics bucket name)
ICEBERG_WAREHOUSE=your-warehouse-name

# Iceberg catalog token
ICEBERG_TOKEN=sb_secret_...

# S3-compatible storage credentials
ICEBERG_S3_ACCESS_KEY=your-s3-access-key
ICEBERG_S3_SECRET_KEY=your-s3-secret-key
ICEBERG_S3_REGION=us-west-2

# S3 and Catalog endpoints (auto-generated from project ref if not set)
# ICEBERG_S3_ENDPOINT=https://your-project.storage.supabase.co/storage/v1/s3
# ICEBERG_CATALOG_URI=https://your-project.storage.supabase.co/storage/v1/iceberg

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================
# Set to 'development' for local, 'production' for prod
NODE_ENV=development
