# ---------------------------------------------------------------------------
# Selestial — Environment variables (example)
# Copy to `.env.local` and fill in real values. NEVER commit real secrets.
# In production (Vercel / Cursor Cloud Agents), set these in the dashboard.
# ---------------------------------------------------------------------------

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
# - STRIPE_SECRET_KEY can be a full secret key (sk_live_...) OR a restricted
#   key (rk_live_...). If using a restricted key, it MUST have these scopes:
#     - customers: write
#     - subscriptions: write
#     - prices + products: read   (required to look up STRIPE_PRICE_ID below)
#     - payment_intents: read
# - STRIPE_PRICE_ID is the Stripe Price id for the $297/mo Selestial plan.
#   Pre-create the Product + recurring Price in the Stripe dashboard, then
#   paste the price id (price_...) here. Used by /api/onboarding/create-subscription.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Twilio (SMS speed-to-lead)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=

# Resend (Email follow-up)
RESEND_API_KEY=

# AI providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Meta (Facebook) Pixel — fired on /demo, /retarget, /offer, /offer/get-started
# Defaults to 350913587937360 if unset (the production pixel for access.selestial.io).
NEXT_PUBLIC_META_PIXEL_ID=350913587937360

# ---------------------------------------------------------------------------
# GoHighLevel (GHL) — Private Integration Token used during onboarding to sync
# contacts, opportunities, and SMS/email conversations from the customer's
# sub-account into Selestial speed-to-lead and re-engagement sequences.
#
# Create a PIT at:  Settings → Private Integrations → New Integration
# Token format:     pit-XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX
# ---------------------------------------------------------------------------
GHL_PRIVATE_INTEGRATION_TOKEN=
GHL_API_BASE_URL=https://services.leadconnectorhq.com
GHL_API_VERSION=2021-07-28
# Optional default location/sub-account to act on when not explicitly passed.
GHL_LOCATION_ID=
# Agency API key — required for sub-account (location) creation, listing, and
# deletion. Distinct from the per-location PIT above. Get it from your GHL
# Agency settings → API Keys. Treat as a secret; never expose to the client.
GHL_AGENCY_API_KEY=
# Optional: snapshot ID to install into every newly-created sub-account.
GHL_DEFAULT_SNAPSHOT_ID=
# Optional: agency company id (the `company_id` claim inside the agency JWT).
# Used as a fallback when a request doesn't pass one explicitly.
GHL_AGENCY_COMPANY_ID=
